    "cors": "^2.8.6",
    "deck.gl": "^9.2.10",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^0.576.0",
    "maplibre-gl": "^5.19.0",
